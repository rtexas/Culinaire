@page "/portal/admin/items"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]
@inject ItemService ItemService
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Items — Culinaire Portal</PageTitle>

<div class="admin-page">
    <div class="module-header">
        <h1 class="page-heading">Items</h1>
    </div>
    <p class="page-sub">Manage menu and inventory items used throughout the portal.</p>

    <!-- ── Import ─────────────────────────────────────────────────────────── -->
    <div class="form-card" style="margin-bottom:28px;">
        <h2 class="form-section-title">Import Items</h2>
        <p style="margin:0 0 12px;font-size:13px;color:var(--color-text-muted);">
            Supported: Excel (.xlsx) or any delimited text file. Required columns:
            <strong>ItemCode</strong>, <strong>ItemName</strong>.
            Optional columns: <strong>ItemDescription</strong>, <strong>TypicalPrice</strong>.
            Existing items matched by ItemCode are updated; new codes are created.
        </p>

        <div class="form-row" style="max-width:480px;">
            <label>File</label>
            <InputFile OnChange="OnFileSelected" accept=".xlsx,.xls,.csv,.txt,.tsv" style="width:100%;" />
        </div>

        @if (_showDelimiter)
        {
            <div class="form-row" style="max-width:280px;">
                <label>Delimiter</label>
                <input type="text" @bind="_delimiter" maxlength="1" style="width:60px;" placeholder="," />
                <span style="font-size:12px;color:var(--color-text-muted);margin-left:8px;">Leave blank for comma</span>
            </div>
        }

        <div class="form-actions">
            <button class="btn-primary" @onclick="RunImportAsync"
                    disabled="@(_importFile is null || _importing)">
                @(_importing ? "Importing…" : "Import")
            </button>
        </div>

        @if (_importResult is not null)
        {
            <div class="alert @(_importResult.HasErrors ? "alert-error" : "alert-success")" style="margin-top:12px;">
                <strong>Import complete.</strong>
                Created: @_importResult.AccountsCreated,
                updated: @_importResult.AccountsUpdated,
                skipped: @_importResult.RowsSkipped.
                @if (_importResult.HasErrors)
                {
                    <ul style="margin:8px 0 0;padding-left:20px;">
                        @foreach (var e in _importResult.Errors) { <li>@e</li> }
                    </ul>
                }
            </div>
        }
    </div>

    <!-- ── Add / Edit Form ────────────────────────────────────────────────── -->
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-error" : "alert-success")" style="margin-bottom:16px;">@_message</div>
    }

    <div class="form-card" style="margin-bottom:24px;">
        <h2 class="form-section-title">@(_editId == 0 ? "Add Item" : "Edit Item")</h2>

        <div class="form-grid-2">
            <div class="form-row">
                <label>Item Code <span class="required">*</span></label>
                <input type="text" @bind="_code" @bind:event="oninput" maxlength="50"
                       placeholder="e.g. BURG01" style="text-transform:uppercase;" />
            </div>
            <div class="form-row">
                <label>Item Name <span class="required">*</span></label>
                <input type="text" @bind="_name" @bind:event="oninput" maxlength="200" placeholder="Item name" />
            </div>
        </div>

        <div class="form-row">
            <label>Description</label>
            <input type="text" @bind="_description" @bind:event="oninput" maxlength="500" placeholder="Optional description" />
        </div>

        <div class="form-row" style="max-width:200px;">
            <label>Typical Price</label>
            <input type="number" @bind="_price" @bind:event="oninput" min="0" step="0.01"
                   placeholder="0.00" style="text-align:right;" />
        </div>

        <div class="form-actions">
            <button class="btn-primary" @onclick="SaveAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_code) || string.IsNullOrWhiteSpace(_name))">
                @(_editId == 0 ? "Add Item" : "Save Changes")
            </button>
            @if (_editId != 0)
            {
                <button class="btn-secondary" @onclick="CancelEdit">Cancel</button>
            }
        </div>
    </div>

    <!-- ── Items Table ────────────────────────────────────────────────────── -->
    <div class="table-card">
        <div style="padding:8px 16px;border-bottom:1px solid var(--color-border);display:flex;align-items:center;gap:12px;">
            <span style="font-size:13px;color:var(--color-text-muted);">@Filtered.Count of @_items.Count item(s)</span>
        </div>
        @if (_items.Count == 0)
        {
            <p style="padding:16px;color:var(--color-text-muted);">No items defined yet. Add one above or import a file.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width:120px;">Code</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th style="width:110px;text-align:right;">Typical Price</th>
                        <th style="width:130px;text-align:center;">Actions</th>
                    </tr>
                    <tr class="filter-row">
                        <th><input type="search" @bind="_fCode" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th><input type="search" @bind="_fName" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th><input type="search" @bind="_fDesc" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Filtered.Count == 0 && _items.Count > 0)
                    {
                        <tr><td colspan="5" style="padding:16px;color:var(--color-text-muted);font-style:italic;text-align:center;">No matching records. Clear the filter to see all items.</td></tr>
                    }
                    @foreach (var item in Filtered)
                    {
                        <tr @key="item.ItemID">
                            <td><code style="font-size:.85rem;">@item.ItemCode</code></td>
                            <td>@item.ItemName</td>
                            <td>@item.ItemDescription</td>
                            <td style="text-align:right;">
                                @(item.TypicalPrice.HasValue ? item.TypicalPrice.Value.ToString("C") : "—")
                            </td>
                            <td style="text-align:center;white-space:nowrap;">
                                <button class="btn-sm btn-secondary" @onclick="() => BeginEdit(item)">Edit</button>
                                <button class="btn-sm btn-danger"    @onclick="() => ConfirmDelete(item)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (_deleteTarget is not null)
{
    <div class="modal-backdrop" @onclick="CancelDelete">
        <div class="modal-box" @onclick:stopPropagation="true">
            <h3>Delete Item</h3>
            <p>Permanently delete <strong>@_deleteTarget.ItemName (@_deleteTarget.ItemCode)</strong>?</p>
            <div class="form-actions">
                <button class="btn-danger"    @onclick="DeleteAsync">Delete</button>
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Portal.Models.Item> _items = [];
    private string _fCode = string.Empty; private string _fName = string.Empty; private string _fDesc = string.Empty;
    private static bool Mtch(string? s, string f) => string.IsNullOrEmpty(f) || (s?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false);
    private List<Portal.Models.Item> Filtered => _items.Where(x => Mtch(x.ItemCode,_fCode) && Mtch(x.ItemName,_fName) && Mtch(x.ItemDescription,_fDesc)).ToList();

    // import state
    private IBrowserFile?              _importFile;
    private bool                       _showDelimiter;
    private string                     _delimiter    = ",";
    private bool                       _importing;
    private Portal.Models.ImportResult? _importResult;

    // CRUD state
    private int      _editId;
    private string   _code        = string.Empty;
    private string   _name        = string.Empty;
    private string   _description = string.Empty;
    private decimal? _price;
    private string   _message     = string.Empty;
    private bool     _isError;
    private Portal.Models.Item? _deleteTarget;

    protected override async Task OnInitializedAsync()
        => _items = await ItemService.GetAllAsync();

    // ── Import ────────────────────────────────────────────────────────────────

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _importFile    = e.File;
        _importResult  = null;
        _showDelimiter = Path.GetExtension(e.File.Name).ToLowerInvariant() is not (".xlsx" or ".xls");
    }

    private async Task RunImportAsync()
    {
        if (_importFile is null) return;
        _importing    = true;
        _importResult = null;
        try
        {
            char delim = _delimiter is { Length: 1 } d ? d[0] : ',';
            await using var stream = _importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _importResult = await ItemService.ImportAsync(stream, _importFile.Name, delim);
            _items        = await ItemService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _importResult = new Portal.Models.ImportResult { Errors = [$"Import failed: {ex.Message}"] };
        }
        finally { _importing = false; }
    }

    // ── CRUD ─────────────────────────────────────────────────────────────────

    private void BeginEdit(Portal.Models.Item item)
    {
        _editId      = item.ItemID;
        _code        = item.ItemCode;
        _name        = item.ItemName;
        _description = item.ItemDescription;
        _price       = item.TypicalPrice;
        _message     = string.Empty;
    }

    private void CancelEdit()
    {
        _editId      = 0;
        _code        = string.Empty;
        _name        = string.Empty;
        _description = string.Empty;
        _price       = null;
    }

    private async Task SaveAsync()
    {
        var item = new Portal.Models.Item
        {
            ItemID          = _editId,
            ItemCode        = _code,
            ItemName        = _name,
            ItemDescription = _description,
            TypicalPrice    = _price,
        };
        try
        {
            if (_editId == 0)
            {
                await ItemService.CreateAsync(item);
                _message = $"Item \"{_name}\" added.";
            }
            else
            {
                await ItemService.UpdateAsync(item);
                _message = $"Item \"{_name}\" updated.";
            }
            _isError = false;
            CancelEdit();
            _items = await ItemService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _message = ex.Message.Contains("UNIQUE") ? $"Item code \"{_code.ToUpperInvariant()}\" already exists." : ex.Message;
            _isError = true;
        }
    }

    private void ConfirmDelete(Portal.Models.Item item) => _deleteTarget = item;
    private void CancelDelete()                          => _deleteTarget = null;

    private async Task DeleteAsync()
    {
        if (_deleteTarget is null) return;
        await ItemService.DeleteAsync(_deleteTarget.ItemID);
        _message     = $"Item \"{_deleteTarget.ItemName}\" deleted.";
        _isError     = false;
        _deleteTarget = null;
        _items       = await ItemService.GetAllAsync();
    }
}
