@page "/portal/admin/shipping-methods"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]
@inject ShippingMethodService MethodService
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Shipping Methods — Culinaire Portal</PageTitle>

<div class="admin-page">
    <div class="module-header">
        <h1 class="page-heading">Shipping Methods</h1>
    </div>
    <p class="page-sub">Manage shipping methods available when entering payable invoices.</p>

    <!-- ── Import ─────────────────────────────────────────────────────────── -->
    <div class="form-card" style="margin-bottom:28px;">
        <h2 class="form-section-title">Import Shipping Methods</h2>
        <p style="margin:0 0 12px;font-size:13px;color:var(--color-text-muted);">
            Supported: Excel (.xlsx) or any delimited text file. Required column: <strong>Name</strong>.
            Optional column: <strong>Description</strong>.
            Existing methods matched by Name are updated; new Names are created.
        </p>

        <div class="form-row" style="max-width:480px;">
            <label>File</label>
            <InputFile OnChange="OnFileSelected" accept=".xlsx,.xls,.csv,.txt,.tsv" style="width:100%;" />
        </div>

        @if (_showDelimiter)
        {
            <div class="form-row" style="max-width:280px;">
                <label>Delimiter</label>
                <input type="text" @bind="_delimiter" maxlength="1" style="width:60px;" placeholder="," />
                <span style="font-size:12px;color:var(--color-text-muted);margin-left:8px;">Leave blank for comma</span>
            </div>
        }

        <div class="form-actions">
            <button class="btn-primary" @onclick="RunImportAsync"
                    disabled="@(_importFile is null || _importing)">
                @(_importing ? "Importing…" : "Import")
            </button>
        </div>

        @if (_importResult is not null)
        {
            <div class="alert @(_importResult.HasErrors ? "alert-error" : "alert-success")" style="margin-top:12px;">
                <strong>Import complete.</strong>
                Created: @_importResult.AccountsCreated,
                updated: @_importResult.AccountsUpdated,
                skipped: @_importResult.RowsSkipped.
                @if (_importResult.HasErrors)
                {
                    <ul style="margin:8px 0 0;padding-left:20px;">
                        @foreach (var e in _importResult.Errors) { <li>@e</li> }
                    </ul>
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-error" : "alert-success")" style="margin-bottom:16px;">@_message</div>
    }

    <!-- ── Add / Edit Form ────────────────────────────────────────────────── -->
    <div class="form-card" style="max-width:600px;margin-bottom:24px;">
        <h2 class="form-section-title">@(_editId == 0 ? "Add Shipping Method" : "Edit Shipping Method")</h2>
        <div class="form-row">
            <label>Name <span class="required">*</span></label>
            <input type="text" @bind="_name" @bind:event="oninput" maxlength="100" placeholder="e.g. FedEx Ground" />
        </div>
        <div class="form-row">
            <label>Description</label>
            <input type="text" @bind="_description" @bind:event="oninput" maxlength="500" placeholder="Optional description" />
        </div>
        <div class="form-actions">
            <button class="btn-primary" @onclick="SaveAsync" disabled="@string.IsNullOrWhiteSpace(_name)">
                @(_editId == 0 ? "Add" : "Save Changes")
            </button>
            @if (_editId != 0)
            {
                <button class="btn-secondary" @onclick="CancelEdit">Cancel</button>
            }
        </div>
    </div>

    <!-- ── List ───────────────────────────────────────────────────────────── -->
    <div class="table-card">
        @if (_methods.Count == 0)
        {
            <p style="padding:16px;color:var(--color-text-muted);">No shipping methods defined yet.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th style="width:130px;text-align:center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in _methods)
                    {
                        <tr @key="m.ShippingMethodID">
                            <td>@m.Name</td>
                            <td>@m.Description</td>
                            <td style="text-align:center;white-space:nowrap;">
                                <button class="btn-sm btn-secondary" @onclick="() => BeginEdit(m)">Edit</button>
                                <button class="btn-sm btn-danger"    @onclick="() => ConfirmDelete(m)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (_deleteTarget is not null)
{
    <div class="modal-backdrop" @onclick="CancelDelete">
        <div class="modal-box" @onclick:stopPropagation="true">
            <h3>Delete Shipping Method</h3>
            <p>Delete <strong>@_deleteTarget.Name</strong>? Payables using this method will have the shipping method cleared.</p>
            <div class="form-actions">
                <button class="btn-danger"    @onclick="DeleteAsync">Delete</button>
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Portal.Models.ShippingMethod> _methods = [];
    private int    _editId;
    private string _name        = string.Empty;
    private string _description = string.Empty;
    private string _message     = string.Empty;
    private bool   _isError;
    private Portal.Models.ShippingMethod? _deleteTarget;

    private IBrowserFile?               _importFile;
    private bool                        _showDelimiter;
    private string                      _delimiter   = ",";
    private bool                        _importing;
    private Portal.Models.ImportResult? _importResult;

    protected override async Task OnInitializedAsync()
        => _methods = await MethodService.GetAllAsync();

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _importFile    = e.File;
        _importResult  = null;
        _showDelimiter = Path.GetExtension(e.File.Name).ToLowerInvariant() is not (".xlsx" or ".xls");
    }

    private async Task RunImportAsync()
    {
        if (_importFile is null) return;
        _importing    = true;
        _importResult = null;
        try
        {
            char delim = _delimiter is { Length: 1 } d ? d[0] : ',';
            await using var stream = _importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _importResult = await MethodService.ImportAsync(stream, _importFile.Name, delim);
            _methods      = await MethodService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _importResult = new Portal.Models.ImportResult { Errors = [$"Import failed: {ex.Message}"] };
        }
        finally { _importing = false; }
    }

    private void BeginEdit(Portal.Models.ShippingMethod m)
    {
        _editId      = m.ShippingMethodID;
        _name        = m.Name;
        _description = m.Description;
        _message     = string.Empty;
    }

    private void CancelEdit()
    {
        _editId      = 0;
        _name        = string.Empty;
        _description = string.Empty;
    }

    private async Task SaveAsync()
    {
        try
        {
            if (_editId == 0)
            {
                await MethodService.CreateAsync(new Portal.Models.ShippingMethod { Name = _name, Description = _description });
                _message = $"Shipping method \"{_name}\" added.";
            }
            else
            {
                await MethodService.UpdateAsync(new Portal.Models.ShippingMethod { ShippingMethodID = _editId, Name = _name, Description = _description });
                _message = $"Shipping method \"{_name}\" updated.";
            }
            _isError = false;
            CancelEdit();
            _methods = await MethodService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _message = ex.Message.Contains("UNIQUE") ? $"A shipping method named \"{_name}\" already exists." : ex.Message;
            _isError = true;
        }
    }

    private void ConfirmDelete(Portal.Models.ShippingMethod m) => _deleteTarget = m;
    private void CancelDelete()                                  => _deleteTarget = null;

    private async Task DeleteAsync()
    {
        if (_deleteTarget is null) return;
        await MethodService.DeleteAsync(_deleteTarget.ShippingMethodID);
        _message     = $"Shipping method \"{_deleteTarget.Name}\" deleted.";
        _isError     = false;
        _deleteTarget = null;
        _methods     = await MethodService.GetAllAsync();
    }
}
