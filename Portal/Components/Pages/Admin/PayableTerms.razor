@page "/portal/admin/payable-terms"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]
@inject PayableTermService TermService
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Due Dates — Culinaire Portal</PageTitle>

<div class="admin-page">
    <div class="module-header">
        <h1 class="page-heading">Due Dates</h1>
    </div>
    <p class="page-sub">
        Configure payment due date terms used on vendor invoices. Each term defines how the due date
        is calculated from the invoice date or the current date.
    </p>

    <!-- ── Import ─────────────────────────────────────────────────────────── -->
    <div class="form-card" style="margin-bottom:28px;">
        <h2 class="form-section-title">Import Due Date Terms</h2>
        <p style="margin:0 0 12px;font-size:13px;color:var(--color-text-muted);">
            Supported: Excel (.xlsx) or any delimited text file. Required column:
            <strong>Name</strong>.
            Optional columns: <strong>Description</strong>, <strong>ExternalCode</strong>,
            <strong>NumberOfDays</strong>, <strong>DateBasis</strong>
            (<code>Invoice</code>, <code>Current</code>, or <code>FixedDOM</code>).
            Existing terms matched by Name are updated; new names are created.
        </p>

        <div class="form-row" style="max-width:480px;">
            <label>File</label>
            <InputFile OnChange="OnFileSelected" accept=".xlsx,.xls,.csv,.txt,.tsv" style="width:100%;" />
        </div>

        @if (_showDelimiter)
        {
            <div class="form-row" style="max-width:280px;">
                <label>Delimiter</label>
                <input type="text" @bind="_delimiter" maxlength="1" style="width:60px;" placeholder="," />
                <span style="font-size:12px;color:var(--color-text-muted);margin-left:8px;">Leave blank for comma</span>
            </div>
        }

        <div class="form-actions">
            <button class="btn-primary" @onclick="RunImportAsync"
                    disabled="@(_importFile is null || _importing)">
                @(_importing ? "Importing…" : "Import")
            </button>
        </div>

        @if (_importResult is not null)
        {
            <div class="alert @(_importResult.HasErrors ? "alert-error" : "alert-success")" style="margin-top:12px;">
                <strong>Import complete.</strong>
                Created: @_importResult.AccountsCreated,
                updated: @_importResult.AccountsUpdated,
                skipped: @_importResult.RowsSkipped.
                @if (_importResult.HasErrors)
                {
                    <ul style="margin:8px 0 0;padding-left:20px;">
                        @foreach (var e in _importResult.Errors) { <li>@e</li> }
                    </ul>
                }
            </div>
        }
    </div>

    <!-- ── Add / Edit Form ────────────────────────────────────────────────── -->
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-error" : "alert-success")" style="margin-bottom:16px;">@_message</div>
    }

    <div class="form-card" style="margin-bottom:24px;">
        <h2 class="form-section-title">@(_editId == 0 ? "Add Due Date Term" : "Edit Due Date Term")</h2>

        <div class="form-grid-2">
            <div class="form-row">
                <label>Name <span class="required">*</span></label>
                <input type="text" @bind="_name" @bind:event="oninput" maxlength="100"
                       placeholder="e.g. NET30" />
            </div>
            <div class="form-row">
                <label>External Code</label>
                <input type="text" @bind="_externalCode" @bind:event="oninput" maxlength="50"
                       placeholder="Code used in external systems" />
            </div>
        </div>

        <div class="form-row">
            <label>Description</label>
            <input type="text" @bind="_description" @bind:event="oninput" maxlength="500"
                   placeholder="Optional description" />
        </div>

        <div class="form-grid-2">
            <div class="form-row">
                <label>Date Basis <span class="required">*</span></label>
                <select @bind="_dateBasis">
                    <option value="Invoice">Days after Invoice Date</option>
                    <option value="Current">Days after Current Date</option>
                    <option value="FixedDOM">Fixed Day of Month</option>
                </select>
                <span style="font-size:12px;color:var(--color-text-muted);margin-top:4px;display:block;">
                    @(_dateBasis == "FixedDOM"
                        ? "Enter the day-of-month (1–31) in Number of Days."
                        : "Enter how many days to add to the selected date.")
                </span>
            </div>
            <div class="form-row">
                <label>
                    @(_dateBasis == "FixedDOM" ? "Day of Month" : "Number of Days")
                </label>
                <input type="number" @bind="_numberOfDays" min="@(_dateBasis == "FixedDOM" ? 1 : 0)"
                       max="@(_dateBasis == "FixedDOM" ? 31 : 9999)"
                       placeholder="@(_dateBasis == "FixedDOM" ? "e.g. 1" : "e.g. 30")"
                       style="max-width:120px;" />
            </div>
        </div>

        @if (_numberOfDays.HasValue)
        {
            <div style="font-size:12px;color:var(--color-text-muted);margin-top:-8px;margin-bottom:12px;">
                Preview: @PreviewDueDate()
            </div>
        }

        <div class="form-actions">
            <button class="btn-primary" @onclick="SaveAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_name))">
                @(_editId == 0 ? "Add Term" : "Save Changes")
            </button>
            @if (_editId != 0)
            {
                <button class="btn-secondary" @onclick="CancelEdit">Cancel</button>
            }
        </div>
    </div>

    <!-- ── Terms Table ───────────────────────────────────────────────────── -->
    <div class="table-card">
        <div style="padding:8px 16px;border-bottom:1px solid var(--color-border);display:flex;align-items:center;gap:12px;">
            <span style="font-size:13px;color:var(--color-text-muted);">@Filtered.Count of @_terms.Count term(s)</span>
        </div>
        @if (_terms.Count == 0)
        {
            <p style="padding:16px;color:var(--color-text-muted);">No due date terms defined yet. Add one above or import a file.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width:120px;">Name</th>
                        <th style="width:100px;">Ext. Code</th>
                        <th>Description</th>
                        <th style="width:160px;">Date Basis</th>
                        <th style="width:100px;text-align:right;">Days / DOM</th>
                        <th style="width:130px;text-align:center;">Actions</th>
                    </tr>
                    <tr class="filter-row">
                        <th><input type="search" @bind="_fName" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th><input type="search" @bind="_fCode" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th><input type="search" @bind="_fDesc" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Filtered.Count == 0 && _terms.Count > 0)
                    {
                        <tr><td colspan="6" style="padding:16px;color:var(--color-text-muted);font-style:italic;text-align:center;">No matching records.</td></tr>
                    }
                    @foreach (var t in Filtered)
                    {
                        <tr @key="t.PayableTermID">
                            <td><strong>@t.Name</strong></td>
                            <td><code style="font-size:.85rem;">@(string.IsNullOrEmpty(t.ExternalCode) ? "—" : t.ExternalCode)</code></td>
                            <td>@t.Description</td>
                            <td>@BasisLabel(t.DateBasis)</td>
                            <td style="text-align:right;">
                                @(t.NumberOfDays.HasValue ? t.NumberOfDays.Value.ToString() : "—")
                            </td>
                            <td style="text-align:center;white-space:nowrap;">
                                <button class="btn-sm btn-secondary" @onclick="() => BeginEdit(t)">Edit</button>
                                <button class="btn-sm btn-danger"    @onclick="() => ConfirmDelete(t)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (_deleteTarget is not null)
{
    <div class="modal-backdrop" @onclick="CancelDelete">
        <div class="modal-box" @onclick:stopPropagation="true">
            <h3>Delete Due Date Term</h3>
            <p>Permanently delete <strong>@_deleteTarget.Name</strong>?</p>
            <p style="font-size:13px;color:var(--color-text-muted);">
                Any invoices using this term will have their term cleared.
            </p>
            <div class="form-actions">
                <button class="btn-danger"    @onclick="DeleteAsync">Delete</button>
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Portal.Models.PayableTerm> _terms = [];
    private string _fName = string.Empty;
    private string _fCode = string.Empty;
    private string _fDesc = string.Empty;

    private static bool Mtch(string? s, string f) =>
        string.IsNullOrEmpty(f) || (s?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false);

    private List<Portal.Models.PayableTerm> Filtered =>
        _terms.Where(x => Mtch(x.Name, _fName) && Mtch(x.ExternalCode, _fCode) && Mtch(x.Description, _fDesc)).ToList();

    // import state
    private IBrowserFile?               _importFile;
    private bool                        _showDelimiter;
    private string                      _delimiter    = ",";
    private bool                        _importing;
    private Portal.Models.ImportResult? _importResult;

    // CRUD state
    private int     _editId;
    private string  _name         = string.Empty;
    private string  _description  = string.Empty;
    private string  _externalCode = string.Empty;
    private int?    _numberOfDays;
    private string  _dateBasis    = "Invoice";
    private string  _message      = string.Empty;
    private bool    _isError;
    private Portal.Models.PayableTerm? _deleteTarget;

    protected override async Task OnInitializedAsync()
        => _terms = await TermService.GetAllAsync();

    // ── Import ────────────────────────────────────────────────────────────────

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _importFile    = e.File;
        _importResult  = null;
        _showDelimiter = Path.GetExtension(e.File.Name).ToLowerInvariant() is not (".xlsx" or ".xls");
    }

    private async Task RunImportAsync()
    {
        if (_importFile is null) return;
        _importing    = true;
        _importResult = null;
        try
        {
            char delim = _delimiter is { Length: 1 } d ? d[0] : ',';
            await using var stream = _importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _importResult = await TermService.ImportAsync(stream, _importFile.Name, delim);
            _terms        = await TermService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _importResult = new Portal.Models.ImportResult { Errors = [$"Import failed: {ex.Message}"] };
        }
        finally { _importing = false; }
    }

    // ── CRUD ─────────────────────────────────────────────────────────────────

    private void BeginEdit(Portal.Models.PayableTerm t)
    {
        _editId       = t.PayableTermID;
        _name         = t.Name;
        _description  = t.Description;
        _externalCode = t.ExternalCode;
        _numberOfDays = t.NumberOfDays;
        _dateBasis    = t.DateBasis;
        _message      = string.Empty;
    }

    private void CancelEdit()
    {
        _editId       = 0;
        _name         = string.Empty;
        _description  = string.Empty;
        _externalCode = string.Empty;
        _numberOfDays = null;
        _dateBasis    = "Invoice";
    }

    private async Task SaveAsync()
    {
        var term = new Portal.Models.PayableTerm
        {
            PayableTermID = _editId,
            Name          = _name,
            Description   = _description,
            ExternalCode  = _externalCode,
            NumberOfDays  = _numberOfDays,
            DateBasis     = _dateBasis,
        };
        try
        {
            if (_editId == 0)
            {
                await TermService.CreateAsync(term);
                _message = $"Term \"{_name}\" added.";
            }
            else
            {
                await TermService.UpdateAsync(term);
                _message = $"Term \"{_name}\" updated.";
            }
            _isError = false;
            CancelEdit();
            _terms = await TermService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _message = ex.Message.Contains("UNIQUE") ? $"Term name \"{_name}\" already exists." : ex.Message;
            _isError = true;
        }
    }

    private void ConfirmDelete(Portal.Models.PayableTerm t) => _deleteTarget = t;
    private void CancelDelete()                               => _deleteTarget = null;

    private async Task DeleteAsync()
    {
        if (_deleteTarget is null) return;
        await TermService.DeleteAsync(_deleteTarget.PayableTermID);
        _message     = $"Term \"{_deleteTarget.Name}\" deleted.";
        _isError     = false;
        _deleteTarget = null;
        _terms       = await TermService.GetAllAsync();
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private string PreviewDueDate()
    {
        var dummy = new Portal.Models.PayableTerm
        {
            DateBasis    = _dateBasis,
            NumberOfDays = _numberOfDays,
        };
        var today   = DateTime.Today;
        var invoice = today;
        var result  = dummy.ComputeDueDate(invoice, today);
        return result.HasValue ? $"Due {result.Value:MMM d, yyyy}" : "—";
    }

    private static string BasisLabel(string basis) => basis switch
    {
        "Invoice"  => "After Invoice Date",
        "Current"  => "After Current Date",
        "FixedDOM" => "Fixed Day of Month",
        _          => basis,
    };
}
