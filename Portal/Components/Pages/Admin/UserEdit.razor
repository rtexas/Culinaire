@page "/portal/admin/users/new"
@page "/portal/admin/users/{UserId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]
@inject UserService        UserService
@inject StateRegionService StateRegionService
@inject CountryService     CountryService
@inject NavigationManager  Nav

<PageTitle>@(_isNew ? "New User" : "Edit User") — Culinaire Portal</PageTitle>

<div class="admin-page">
    <div class="module-header">
        <h1 class="page-heading">@(_isNew ? "New User" : "Edit User")</h1>
        <button class="btn-secondary" @onclick="GoBack">← Back</button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <div class="alert alert-error">@_errorMsg</div>
    }
    @if (!string.IsNullOrEmpty(_successMsg))
    {
        <div class="alert alert-success">@_successMsg</div>
    }

    <div class="form-card">
        <div class="form-section-title">Account</div>

        <div class="form-grid-2">
            <div class="form-row">
                <label>Username <span class="required">*</span></label>
                <input type="text" @bind="_username" disabled="@(!_isNew)" />
            </div>
            <div class="form-row">
                <label>Full Name <span class="required">*</span></label>
                <input type="text" @bind="_fullName" />
            </div>
        </div>
        <div class="form-grid-2">
            <div class="form-row">
                <label>Email</label>
                <input type="email" @bind="_email" />
            </div>
            <div class="form-row">
                <label>Role <span class="required">*</span></label>
                <select @bind="_roleType">
                    <option value="Administrator">Administrator</option>
                    <option value="User">User</option>
                    <option value="Viewer">Viewer</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <label>Active</label>
            <input type="checkbox" @bind="_isActive" />
        </div>

        <div class="form-section-title" style="margin-top:1.5rem;">
            @(_isNew ? "Password" : "Change Password (leave blank to keep current)")
        </div>
        <div class="form-grid-2">
            <div class="form-row">
                <label>@(_isNew ? "Password *" : "New Password")</label>
                <input type="password" @bind="_password" />
            </div>
            <div class="form-row">
                <label>@(_isNew ? "Confirm Password *" : "Confirm New Password")</label>
                <input type="password" @bind="_confirmPassword" />
            </div>
        </div>

        <div class="form-section-title" style="margin-top:1.5rem;">Address (optional)</div>

        <div class="form-row">
            <label>Address Line 1</label>
            <input type="text" @bind="_address1" />
        </div>
        <div class="form-row">
            <label>Address Line 2</label>
            <input type="text" @bind="_address2" />
        </div>
        <div class="form-row">
            <label>Address Line 3</label>
            <input type="text" @bind="_address3" />
        </div>

        <div class="form-grid-3">
            <div class="form-row">
                <label>City</label>
                <input type="text" @bind="_city" />
            </div>
            <div class="form-row">
                <label>State / Region</label>
                <select @bind="_stateRegionId">
                    <option value="0">— None —</option>
                    @foreach (var s in _states)
                    {
                        <option value="@s.StateRegionID">@s.Code — @s.Name</option>
                    }
                </select>
            </div>
            <div class="form-row">
                <label>Postal Code</label>
                <input type="text" @bind="_postalCode" />
            </div>
        </div>

        <div class="form-row">
            <label>Country</label>
            <select @bind="_countryId">
                <option value="0">— None —</option>
                @foreach (var c in _countries)
                {
                    <option value="@c.CountryID">@c.Code — @c.Name</option>
                }
            </select>
        </div>

        <div class="form-actions">
            <button class="btn-primary" @onclick="SaveAsync">Save</button>
            <button class="btn-secondary" @onclick="GoBack">Cancel</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? UserId { get; set; }

    private void GoBack() => Nav.NavigateTo("/portal/admin/users");

    private bool   _isNew           = true;
    private string _username        = string.Empty;
    private string _fullName        = string.Empty;
    private string _email           = string.Empty;
    private string _roleType        = "User";
    private bool   _isActive        = true;
    private string _password        = string.Empty;
    private string _confirmPassword = string.Empty;

    // address
    private string _address1    = string.Empty;
    private string _address2    = string.Empty;
    private string _address3    = string.Empty;
    private string _city        = string.Empty;
    private int    _stateRegionId = 0;
    private string _postalCode  = string.Empty;
    private int    _countryId   = 0;

    private string _errorMsg   = string.Empty;
    private string _successMsg = string.Empty;

    private List<Portal.Models.StateRegion> _states    = [];
    private List<Portal.Models.Country>     _countries = [];

    protected override async Task OnInitializedAsync()
    {
        _states    = await StateRegionService.GetAllAsync();
        _countries = await CountryService.GetAllAsync();

        _isNew = UserId == null;
        if (!_isNew)
        {
            var user = await UserService.GetByIdAsync(UserId!.Value);
            if (user != null)
            {
                _username      = user.Username;
                _fullName      = user.FullName;
                _email         = user.Email ?? string.Empty;
                _roleType      = user.RoleType;
                _isActive      = user.IsActive;
                _address1      = user.Address1 ?? string.Empty;
                _address2      = user.Address2 ?? string.Empty;
                _address3      = user.Address3 ?? string.Empty;
                _city          = user.City ?? string.Empty;
                _stateRegionId = user.StateRegionID ?? 0;
                _postalCode    = user.PostalCode ?? string.Empty;
                _countryId     = user.CountryID ?? 0;
            }
        }
    }

    private async Task SaveAsync()
    {
        _errorMsg   = string.Empty;
        _successMsg = string.Empty;

        if (string.IsNullOrWhiteSpace(_username)) { _errorMsg = "Username is required."; return; }
        if (string.IsNullOrWhiteSpace(_fullName))  { _errorMsg = "Full Name is required."; return; }
        if (_isNew && string.IsNullOrWhiteSpace(_password)) { _errorMsg = "Password is required."; return; }
        if (!string.IsNullOrEmpty(_password) && _password != _confirmPassword)
        { _errorMsg = "Passwords do not match."; return; }

        if (await UserService.UsernameExistsAsync(_username, _isNew ? 0 : UserId!.Value))
        { _errorMsg = "Username already exists."; return; }

        var user = new Portal.Models.User
        {
            UserID        = _isNew ? 0 : UserId!.Value,
            Username      = _username,
            FullName      = _fullName,
            Email         = string.IsNullOrWhiteSpace(_email) ? null : _email,
            RoleType      = _roleType,
            IsActive      = _isActive,
            Address1      = string.IsNullOrWhiteSpace(_address1) ? null : _address1,
            Address2      = string.IsNullOrWhiteSpace(_address2) ? null : _address2,
            Address3      = string.IsNullOrWhiteSpace(_address3) ? null : _address3,
            City          = string.IsNullOrWhiteSpace(_city) ? null : _city,
            StateRegionID = _stateRegionId == 0 ? null : _stateRegionId,
            PostalCode    = string.IsNullOrWhiteSpace(_postalCode) ? null : _postalCode,
            CountryID     = _countryId == 0 ? null : _countryId,
        };

        if (_isNew)
        {
            await UserService.CreateAsync(user, _password);
        }
        else
        {
            await UserService.UpdateAsync(user);
            if (!string.IsNullOrWhiteSpace(_password))
                await UserService.ChangePasswordAsync(UserId!.Value, _password);
        }

        _successMsg      = _isNew ? "User created successfully." : "User updated successfully.";
        _password        = string.Empty;
        _confirmPassword = string.Empty;

        if (_isNew) Nav.NavigateTo("/portal/admin/users");
    }
}
