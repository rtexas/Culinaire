@page "/portal/admin/account-categories"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]
@inject AccountCategoryService CategoryService

<PageTitle>Account Categories — Culinaire Portal</PageTitle>

<div class="admin-page">
    <div class="module-header">
        <h1 class="page-heading">Account Categories</h1>
    </div>
    <p class="page-sub">
        Account Categories are created automatically when accounts are imported via
        <a href="/portal/admin/chart-of-accounts">Chart of Accounts</a>.
        To add a new category, import a Chart of Accounts entry that uses it.
    </p>

    <ReadOnlyLookupList TItem="Portal.Models.AccountCategory"
        Items="_categories"
        GetKey="x => x.CategoryID"
        GetName="x => x.Name"
        GetDescription="x => x.Description"
        EmptyMessage="No account categories defined yet. Import accounts via Chart of Accounts to populate this list." />
</div>

@code {
    private List<Portal.Models.AccountCategory> _categories = [];

    protected override async Task OnInitializedAsync()
        => _categories = await CategoryService.GetAllAsync();
}
