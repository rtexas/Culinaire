@page "/portal/admin/eod-columns"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]
@inject EodColumnService   EodColumnService
@inject CoaSegmentsService CoaSegmentsService
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>EOD Sales — Columns — Culinaire Portal</PageTitle>

<div class="admin-page">
    <div class="module-header">
        <h1 class="page-heading">EOD Sales — Columns</h1>
    </div>
    <p class="page-sub">
        Define the department columns used on the EOD Sales entry grid.
        Each column can be linked to a Chart of Accounts segment to map department sales to the correct CoA dimension.
    </p>

    <!-- ── Import ─────────────────────────────────────────────────────────── -->
    <div class="form-card" style="margin-bottom:28px;">
        <h2 class="form-section-title">Import Columns</h2>
        <p style="margin:0 0 12px;font-size:13px;color:var(--color-text-muted);">
            Supported: Excel (.xlsx) or any delimited text file. Required column: <strong>Name</strong>.
            Optional: <strong>Description</strong>, <strong>CoA Segment</strong> (0–@_maxSegment; defaults to 0).
            Existing records matched by Name are updated; new Names are inserted.
        </p>
        <div class="form-row" style="max-width:480px;">
            <label>File</label>
            <InputFile OnChange="OnFileSelected" accept=".xlsx,.xls,.csv,.txt,.tsv" style="width:100%;" />
        </div>
        @if (_showDelimiter)
        {
            <div class="form-row" style="max-width:280px;">
                <label>Delimiter</label>
                <input type="text" @bind="_delimiter" maxlength="1" style="width:60px;" placeholder="," />
                <span style="font-size:12px;color:var(--color-text-muted);margin-left:8px;">Leave blank for comma</span>
            </div>
        }
        <div class="form-actions">
            <button class="btn-primary" @onclick="ImportAsync" disabled="@(_importFile is null || _importing)">
                @(_importing ? "Importing…" : "Import")
            </button>
        </div>
        @if (_importResult is not null)
        {
            <div class="alert @(_importResult.HasErrors ? "alert-error" : "alert-success")" style="margin-top:12px;">
                <strong>Import complete.</strong>
                Created: @_importResult.AccountsCreated, updated: @_importResult.AccountsUpdated, skipped: @_importResult.RowsSkipped.
                @if (_importResult.HasErrors)
                {
                    <ul style="margin:8px 0 0;padding-left:20px;">
                        @foreach (var e in _importResult.Errors) { <li>@e</li> }
                    </ul>
                }
            </div>
        }
    </div>

    <!-- ── Add / Edit ─────────────────────────────────────────────────────── -->
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-error" : "alert-success")" style="margin-bottom:16px;">@_message</div>
    }

    <div class="form-card" style="max-width:680px;margin-bottom:24px;">
        <h2 class="form-section-title">@(_editId == 0 ? "Add Column" : "Edit Column")</h2>

        <div style="display:grid;grid-template-columns:1fr 220px;gap:12px;">
            <div class="form-row">
                <label>Name <span class="required">*</span></label>
                <input type="text" @bind="_name" @bind:event="oninput" maxlength="200" placeholder="e.g. Kitchen" />
            </div>
            <div class="form-row">
                <label title="Which CoA segment this department maps to. 0 = not linked.">
                    CoA Segment
                    @if (_maxSegment > 0)
                    {
                        <span style="font-size:11px;color:var(--color-text-muted);margin-left:4px;">(0–@_maxSegment)</span>
                    }
                </label>
                <select @bind="_coaSegmentNumber">
                    <option value="0">0 — Not Linked</option>
                    @foreach (var seg in _segments)
                    {
                        <option value="@seg.SegmentNumber">@seg.SegmentNumber — @seg.Description</option>
                    }
                </select>
            </div>
        </div>

        @if (_coaSegmentNumber > 0)
        {
            <div class="form-row" style="max-width:320px;">
                <label title="The value at segment position @_coaSegmentNumber that appears in the G/L account string (e.g. KITCH, BAR).">
                    Segment Value
                </label>
                <input type="text" @bind="_segmentValue" @bind:event="oninput" maxlength="50"
                       placeholder="e.g. KITCH" />
            </div>
        }

        <div class="form-row">
            <label>Description</label>
            <input type="text" @bind="_description" @bind:event="oninput" maxlength="500" placeholder="Optional description" />
        </div>

        @if (_maxSegment == 0)
        {
            <p style="font-size:12px;color:var(--color-text-muted);margin:0 0 12px;">
                No CoA segments defined yet. Configure segments in
                <a href="/portal/admin/chart-of-accounts">Chart of Accounts</a>.
            </p>
        }

        <div class="form-actions">
            <button class="btn-primary" @onclick="SaveAsync" disabled="@string.IsNullOrWhiteSpace(_name)">
                @(_editId == 0 ? "Add" : "Save Changes")
            </button>
            @if (_editId != 0)
            {
                <button class="btn-secondary" @onclick="CancelEdit">Cancel</button>
            }
        </div>
    </div>

    <!-- ── List ───────────────────────────────────────────────────────────── -->
    <div class="table-card">
        <div style="padding:8px 16px;border-bottom:1px solid var(--color-border);display:flex;align-items:center;gap:12px;">
            <span style="font-size:13px;color:var(--color-text-muted);">@Filtered.Count of @_items.Count record(s)</span>
        </div>
        @if (_items.Count == 0)
        {
            <p style="padding:16px;color:var(--color-text-muted);">No columns defined yet. Add one above or import a file.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th style="width:160px;text-align:center;">CoA Segment</th>
                        <th style="width:110px;text-align:center;">Seg Value</th>
                        <th style="width:120px;text-align:center;">Actions</th>
                    </tr>
                    <tr class="filter-row">
                        <th><input type="search" @bind="_fName" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th><input type="search" @bind="_fDesc" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th></th>
                        <th><input type="search" @bind="_fSegVal" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Filtered.Count == 0 && _items.Count > 0)
                    {
                        <tr><td colspan="5" style="padding:16px;color:var(--color-text-muted);font-style:italic;text-align:center;">No matching records. Clear the filter to see all items.</td></tr>
                    }
                    @foreach (var item in Filtered)
                    {
                        <tr @key="item.ColumnID">
                            <td>@item.Name</td>
                            <td>@item.Description</td>
                            <td style="text-align:center;">
                                @if (item.CoaSegmentNumber > 0)
                                {
                                    <span class="status-badge"
                                          style="background:color-mix(in srgb,var(--color-primary) 12%,transparent);color:var(--color-primary);">
                                        Seg @item.CoaSegmentNumber
                                        @if (!string.IsNullOrEmpty(item.CoaSegmentDescription))
                                        {
                                            <span style="font-weight:400;margin-left:4px;">— @item.CoaSegmentDescription</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--color-text-muted);font-size:.8rem;">—</span>
                                }
                            </td>
                            <td style="text-align:center;">
                                @if (!string.IsNullOrEmpty(item.SegmentValue))
                                {
                                    <code style="font-size:.85rem;">@item.SegmentValue</code>
                                }
                                else { <span style="color:var(--color-text-muted);font-size:.8rem;">—</span> }
                            </td>
                            <td style="text-align:center;white-space:nowrap;">
                                <button class="btn-sm btn-secondary" @onclick="() => BeginEdit(item)">Edit</button>
                                <button class="btn-sm btn-danger"    @onclick="() => ConfirmDelete(item)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (_deleteTarget is not null)
{
    <div class="modal-backdrop" @onclick="CancelDelete">
        <div class="modal-box" @onclick:stopPropagation="true">
            <h3>Delete Column</h3>
            <p>Permanently delete <strong>@_deleteTarget.Name</strong>?</p>
            <div class="form-actions">
                <button class="btn-danger"    @onclick="DeleteAsync">Delete</button>
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Portal.Models.EodColumn>  _items    = [];
    private string _fName = string.Empty; private string _fDesc = string.Empty; private string _fSegVal = string.Empty;
    private static bool Mtch(string? s, string f) => string.IsNullOrEmpty(f) || (s?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false);
    private List<Portal.Models.EodColumn> Filtered => _items.Where(x => Mtch(x.Name,_fName) && Mtch(x.Description,_fDesc) && Mtch(x.SegmentValue,_fSegVal)).ToList();
    private List<Portal.Models.CoaSegment> _segments = [];
    private int                            _maxSegment;

    private IBrowserFile?               _importFile;
    private bool                        _showDelimiter;
    private string                      _delimiter    = ",";
    private bool                        _importing;
    private Portal.Models.ImportResult? _importResult;

    private int    _editId           = 0;
    private string _name             = string.Empty;
    private string _description      = string.Empty;
    private int    _coaSegmentNumber  = 0;
    private string _segmentValue      = string.Empty;
    private string _message         = string.Empty;
    private bool   _isError;
    private Portal.Models.EodColumn? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        var colTask = EodColumnService.GetAllAsync();
        var segTask = CoaSegmentsService.GetAllAsync();
        var maxTask = CoaSegmentsService.GetMaxSegmentAsync();
        await Task.WhenAll(colTask, segTask, maxTask);
        _items      = colTask.Result;
        _segments   = segTask.Result;
        _maxSegment = maxTask.Result;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _importFile    = e.File;
        _importResult  = null;
        _showDelimiter = Path.GetExtension(e.File.Name).ToLowerInvariant() is not (".xlsx" or ".xls");
    }

    private async Task ImportAsync()
    {
        if (_importFile is null) return;
        _importing = true; _importResult = null;
        try
        {
            char delim = _delimiter is { Length: 1 } d ? d[0] : ',';
            await using var stream = _importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _importResult = await EodColumnService.ImportAsync(stream, _importFile.Name, delim);
            _items = await EodColumnService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _importResult = new Portal.Models.ImportResult { Errors = [$"Import failed: {ex.Message}"] };
        }
        finally { _importing = false; }
    }

    private void BeginEdit(Portal.Models.EodColumn item)
    {
        _editId           = item.ColumnID;
        _name             = item.Name;
        _description      = item.Description;
        _coaSegmentNumber = item.CoaSegmentNumber;
        _segmentValue     = item.SegmentValue;
        _message          = string.Empty;
    }

    private void CancelEdit()
    {
        _editId = 0; _name = string.Empty; _description = string.Empty;
        _coaSegmentNumber = 0; _segmentValue = string.Empty;
    }

    private async Task SaveAsync()
    {
        var item = new Portal.Models.EodColumn
        {
            ColumnID         = _editId,
            Name             = _name,
            Description      = _description,
            CoaSegmentNumber = _coaSegmentNumber,
            SegmentValue     = _coaSegmentNumber > 0 ? _segmentValue : string.Empty,
        };
        try
        {
            if (_editId == 0) { await EodColumnService.CreateAsync(item); _message = $"Added: {_name}."; }
            else              { await EodColumnService.UpdateAsync(item); _message = $"Updated: {_name}."; }
            _isError = false;
            CancelEdit();
            _items = await EodColumnService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _message = ex.Message.Contains("UNIQUE") ? $"\"{_name}\" already exists." : ex.Message;
            _isError = true;
        }
    }

    private void ConfirmDelete(Portal.Models.EodColumn item) => _deleteTarget = item;
    private void CancelDelete()                               => _deleteTarget = null;

    private async Task DeleteAsync()
    {
        if (_deleteTarget is null) return;
        try
        {
            await EodColumnService.DeleteAsync(_deleteTarget.ColumnID);
            _message = $"Deleted: {_deleteTarget.Name}."; _isError = false;
        }
        catch (Exception ex) { _message = ex.Message; _isError = true; }
        _deleteTarget = null;
        _items = await EodColumnService.GetAllAsync();
    }
}
