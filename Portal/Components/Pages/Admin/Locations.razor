@page "/portal/admin/locations"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]
@inject LocationService    LocationService
@inject CoaSegmentsService CoaSegmentsService
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Locations — Culinaire Portal</PageTitle>

<div class="admin-page">
    <div class="module-header">
        <h1 class="page-heading">Locations</h1>
    </div>
    <p class="page-sub">
        Each location is a physical restaurant building. The CoA Segment links the location code
        to a specific segment position in the Chart of Accounts (e.g. Segment 2 in
        <strong>Dept — Location — Natural Account</strong>).
        Set to <strong>0 — Not Linked</strong> if locations are not part of your COA structure;
        account lists will then show the full unfiltered COA.
    </p>

    <!-- ── Import ─────────────────────────────────────────────────────────── -->
    <div class="form-card" style="margin-bottom:28px;">
        <h2 class="form-section-title">Import Locations</h2>
        <p style="margin:0 0 12px;font-size:13px;color:var(--color-text-muted);">
            Supported: Excel (.xlsx) or any delimited text file. Required columns:
            <strong>Code</strong>, <strong>Name</strong>.
            Optional: <strong>Description</strong>, <strong>Segment Number</strong>,
            <strong>Address1</strong>, <strong>Address2</strong>, <strong>City</strong>,
            <strong>State</strong>, <strong>Zip</strong>.
            Existing records matched by Code are updated; new Codes are inserted.
        </p>

        <div class="form-row" style="max-width:480px;">
            <label>File</label>
            <InputFile OnChange="OnFileSelected" accept=".xlsx,.xls,.csv,.txt,.tsv" style="width:100%;" />
        </div>

        @if (_showDelimiter)
        {
            <div class="form-row" style="max-width:280px;">
                <label>Delimiter</label>
                <input type="text" @bind="_delimiter" maxlength="1" style="width:60px;" placeholder="," />
                <span style="font-size:12px;color:var(--color-text-muted);margin-left:8px;">Leave blank for comma</span>
            </div>
        }

        <div class="form-actions">
            <button class="btn-primary" @onclick="ImportAsync" disabled="@(_importFile is null || _importing)">
                @(_importing ? "Importing…" : "Import")
            </button>
        </div>

        @if (_importResult is not null)
        {
            <div class="alert @(_importResult.HasErrors ? "alert-error" : "alert-success")" style="margin-top:12px;">
                <strong>Import complete.</strong>
                Created: @_importResult.AccountsCreated,
                updated: @_importResult.AccountsUpdated,
                skipped: @_importResult.RowsSkipped.
                @if (_importResult.HasErrors)
                {
                    <ul style="margin:8px 0 0;padding-left:20px;">
                        @foreach (var e in _importResult.Errors) { <li>@e</li> }
                    </ul>
                }
            </div>
        }
    </div>

    <!-- ── Add / Edit Form ───────────────────────────────────────────────── -->
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-error" : "alert-success")" style="margin-bottom:16px;">@_message</div>
    }

    <div class="form-card" style="max-width:760px;margin-bottom:24px;">
        <h2 class="form-section-title">@(_editId == 0 ? "Add Location" : "Edit Location")</h2>

        <div style="display:grid;grid-template-columns:1fr 140px 180px;gap:12px;">
            <div class="form-row">
                <label>Name <span class="required">*</span></label>
                <input type="text" @bind="_name" @bind:event="oninput" maxlength="100" placeholder="e.g. Main Restaurant" />
            </div>
            <div class="form-row">
                <label>Code <span class="required">*</span></label>
                <input type="text" @bind="_code" @bind:event="oninput" maxlength="20"
                       placeholder="e.g. 001" style="text-transform:uppercase;" />
            </div>
            <div class="form-row">
                <label title="Which COA segment position this location's code occupies. 0 = not linked to COA.">
                    CoA Segment
                </label>
                <select @bind="_segmentNumber">
                    <option value="0">0 — Not Linked</option>
                    @foreach (var seg in _segments)
                    {
                        <option value="@seg.SegmentNumber">@seg.SegmentNumber — @seg.Description</option>
                    }
                </select>
            </div>
        </div>

        <div class="form-row">
            <label>Description</label>
            <input type="text" @bind="_description" @bind:event="oninput" maxlength="500" placeholder="Optional description" />
        </div>

        <div class="form-section-divider" style="margin:12px 0;"></div>
        <h3 class="form-section-title" style="font-size:.9rem;margin-bottom:10px;">Physical Address</h3>

        <div class="form-row">
            <label>Address 1</label>
            <input type="text" @bind="_address1" maxlength="100" placeholder="Street address" style="max-width:420px;" />
        </div>
        <div class="form-row">
            <label>Address 2</label>
            <input type="text" @bind="_address2" maxlength="100" placeholder="Suite, unit, etc." style="max-width:420px;" />
        </div>
        <div style="display:grid;grid-template-columns:1fr 80px 110px;gap:12px;max-width:560px;">
            <div class="form-row">
                <label>City</label>
                <input type="text" @bind="_city" maxlength="100" />
            </div>
            <div class="form-row">
                <label>State</label>
                <input type="text" @bind="_state" maxlength="50" />
            </div>
            <div class="form-row">
                <label>Zip</label>
                <input type="text" @bind="_zip" maxlength="20" />
            </div>
        </div>

        <div class="form-actions">
            <button class="btn-primary" @onclick="SaveAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_code))">
                @(_editId == 0 ? "Add" : "Save Changes")
            </button>
            @if (_editId != 0)
            {
                <button class="btn-secondary" @onclick="CancelEdit">Cancel</button>
            }
        </div>
    </div>

    <!-- ── List ──────────────────────────────────────────────────────────── -->
    <div class="table-card">
        <div style="padding:8px 16px;border-bottom:1px solid var(--color-border);display:flex;align-items:center;gap:12px;">
            <span style="font-size:13px;color:var(--color-text-muted);">@Filtered.Count of @_items.Count record(s)</span>
        </div>
        @if (_items.Count == 0)
        {
            <p style="padding:16px;color:var(--color-text-muted);">No locations defined yet. Add one above or import a file.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width:80px;">Code</th>
                        <th style="width:160px;">Name</th>
                        <th>Address</th>
                        <th>Description</th>
                        <th style="width:110px;text-align:center;">Actions</th>
                    </tr>
                    <tr class="filter-row">
                        <th><input type="search" @bind="_fCode" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th><input type="search" @bind="_fName" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th><input type="search" @bind="_fAddr" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th><input type="search" @bind="_fDesc" @bind:event="oninput" placeholder="Filter…" /></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Filtered.Count == 0 && _items.Count > 0)
                    {
                        <tr><td colspan="5" style="padding:16px;color:var(--color-text-muted);font-style:italic;text-align:center;">No matching records. Clear the filter to see all items.</td></tr>
                    }
                    @foreach (var item in Filtered)
                    {
                        <tr @key="item.LocationID">
                            <td><code style="font-size:.85rem;">@item.Code</code></td>
                            <td>@item.Name</td>
                            <td style="font-size:12px;color:var(--color-text-muted);">
                                @{
                                    var addrParts = new List<string>();
                                    if (!string.IsNullOrEmpty(item.Address1)) addrParts.Add(item.Address1);
                                    if (!string.IsNullOrEmpty(item.Address2)) addrParts.Add(item.Address2);
                                    var cityLine = string.Join(", ", new[] { item.City, item.State }.Where(x => !string.IsNullOrEmpty(x)));
                                    if (!string.IsNullOrEmpty(item.Zip)) cityLine += (string.IsNullOrEmpty(cityLine) ? "" : " ") + item.Zip;
                                    if (!string.IsNullOrEmpty(cityLine)) addrParts.Add(cityLine);
                                }
                                @string.Join(" · ", addrParts)
                            </td>
                            <td style="font-size:12px;color:var(--color-text-muted);">@item.Description</td>
                            <td style="text-align:center;white-space:nowrap;">
                                <button class="btn-sm btn-secondary" @onclick="() => BeginEdit(item)">Edit</button>
                                <button class="btn-sm btn-danger"    @onclick="() => ConfirmDelete(item)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (_deleteTarget is not null)
{
    <div class="modal-backdrop" @onclick="CancelDelete">
        <div class="modal-box" @onclick:stopPropagation="true">
            <h3>Delete Location</h3>
            <p>Permanently delete <strong>@_deleteTarget.Name (@_deleteTarget.Code)</strong>?</p>
            <div class="form-actions">
                <button class="btn-danger"    @onclick="DeleteAsync">Delete</button>
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Portal.Models.Location>   _items    = [];
    private string _fCode = string.Empty; private string _fName = string.Empty; private string _fAddr = string.Empty; private string _fDesc = string.Empty;
    private static bool Mtch(string? s, string f) => string.IsNullOrEmpty(f) || (s?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false);
    private List<Portal.Models.Location> Filtered => _items.Where(x => Mtch(x.Code,_fCode) && Mtch(x.Name,_fName) && (string.IsNullOrEmpty(_fAddr)||Mtch(x.City,_fAddr)||Mtch(x.State,_fAddr)) && Mtch(x.Description,_fDesc)).ToList();
    private List<Portal.Models.CoaSegment> _segments = [];

    private IBrowserFile?               _importFile;
    private bool                        _showDelimiter;
    private string                      _delimiter    = ",";
    private bool                        _importing;
    private Portal.Models.ImportResult? _importResult;

    private int    _editId        = 0;
    private string _name          = string.Empty;
    private string _code          = string.Empty;
    private string _description   = string.Empty;
    private int    _segmentNumber = 0;
    private string _address1      = string.Empty;
    private string _address2      = string.Empty;
    private string _city          = string.Empty;
    private string _state         = string.Empty;
    private string _zip           = string.Empty;
    private string _message       = string.Empty;
    private bool   _isError;
    private Portal.Models.Location? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        var itemsTask = LocationService.GetAllAsync();
        var segTask   = CoaSegmentsService.GetAllAsync();
        await Task.WhenAll(itemsTask, segTask);
        _items    = itemsTask.Result;
        _segments = segTask.Result;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _importFile   = e.File;
        _importResult = null;
        var ext = Path.GetExtension(e.File.Name).ToLowerInvariant();
        _showDelimiter = ext is not (".xlsx" or ".xls");
    }

    private async Task ImportAsync()
    {
        if (_importFile is null) return;
        _importing    = true;
        _importResult = null;
        try
        {
            char delim = _delimiter is { Length: 1 } d ? d[0] : ',';
            await using var stream = _importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _importResult = await LocationService.ImportAsync(stream, _importFile.Name, delim);
            _items = await LocationService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _importResult = new Portal.Models.ImportResult { Errors = [$"Import failed: {ex.Message}"] };
        }
        finally { _importing = false; }
    }

    private void BeginEdit(Portal.Models.Location item)
    {
        _editId        = item.LocationID;
        _name          = item.Name;
        _code          = item.Code;
        _description   = item.Description;
        _segmentNumber = item.SegmentNumber;
        _address1      = item.Address1;
        _address2      = item.Address2;
        _city          = item.City;
        _state         = item.State;
        _zip           = item.Zip;
        _message       = string.Empty;
    }

    private void CancelEdit()
    {
        _editId        = 0;
        _name          = string.Empty;
        _code          = string.Empty;
        _description   = string.Empty;
        _segmentNumber = 0;
        _address1      = string.Empty;
        _address2      = string.Empty;
        _city          = string.Empty;
        _state         = string.Empty;
        _zip           = string.Empty;
    }

    private async Task SaveAsync()
    {
        var item = new Portal.Models.Location
        {
            LocationID    = _editId,
            Name          = _name,
            Code          = _code,
            Description   = _description,
            SegmentNumber = _segmentNumber,
            Address1      = _address1,
            Address2      = _address2,
            City          = _city,
            State         = _state,
            Zip           = _zip,
        };
        try
        {
            if (_editId == 0)
            {
                await LocationService.CreateAsync(item);
                _message = $"Added: {_name} ({_code.ToUpperInvariant()}).";
            }
            else
            {
                await LocationService.UpdateAsync(item);
                _message = $"Updated: {_name} ({_code.ToUpperInvariant()}).";
            }
            _isError = false;
            CancelEdit();
            _items = await LocationService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _message = ex.Message.Contains("UNIQUE") ? $"Code \"{_code.ToUpperInvariant()}\" already exists." : ex.Message;
            _isError = true;
        }
    }

    private void ConfirmDelete(Portal.Models.Location item) => _deleteTarget = item;
    private void CancelDelete()                              => _deleteTarget = null;

    private async Task DeleteAsync()
    {
        if (_deleteTarget is null) return;
        try
        {
            await LocationService.DeleteAsync(_deleteTarget.LocationID);
            _message = $"Deleted: {_deleteTarget.Name} ({_deleteTarget.Code}).";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = ex.Message.Contains("REFERENCE")
                ? "Cannot delete — this location is still assigned to users."
                : ex.Message;
            _isError = true;
        }
        _deleteTarget = null;
        _items = await LocationService.GetAllAsync();
    }
}
