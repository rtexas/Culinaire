@page "/login"
@model Portal.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Culinaire Portal</title>
    <link rel="stylesheet" href="/app.css" />
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--color-bg, #f5f5f5);
            font-family: system-ui, -apple-system, sans-serif;
        }
        .login-card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 24px rgba(0,0,0,.12);
            width: 380px;
            max-width: 95vw;
            padding: 40px 36px 32px;
        }
        .login-logo {
            text-align: center;
            margin-bottom: 28px;
        }
        .login-logo img { max-height: 90px; max-width: 220px; object-fit: contain; }
        .login-logo .portal-name {
            font-size: 1.5rem; font-weight: 700;
            color: var(--color-primary, #2B6B35);
            margin-top: 8px;
            display: block;
        }
        .login-logo .tagline {
            font-size: .78rem;
            color: #666;
            display: block;
        }
        label { display: block; font-size: .85rem; font-weight: 600; margin-bottom: 4px; color: #333; }
        input[type=text], input[type=password] {
            width: 100%; box-sizing: border-box;
            padding: 9px 12px; border: 1.5px solid #d0d5dd;
            border-radius: 6px; font-size: .95rem;
            transition: border-color .15s;
            margin-bottom: 16px;
        }
        input:focus { outline: none; border-color: var(--color-primary, #2B6B35); }
        .remember { display: flex; align-items: center; gap: 8px; font-size: .85rem; margin-bottom: 20px; }
        .btn-login {
            width: 100%; padding: 11px;
            background: var(--color-primary, #2B6B35);
            color: #fff; border: none; border-radius: 6px;
            font-size: 1rem; font-weight: 600; cursor: pointer;
            transition: background .15s;
        }
        .btn-login:hover { background: var(--color-accent, #1A4A22); }
        .error-msg { color: #c0392b; font-size: .85rem; margin-bottom: 12px; padding: 8px 10px; background: #fef2f2; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">
            <img src="/images/logo.png" alt="Culinaire logo" onerror="this.style.display='none'" />
            <span class="portal-name">Culinaire</span>
            <span class="tagline">Distinctive Dining &amp; Hospitality Management</span>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error-msg">@Model.ErrorMessage</div>
        }

        <form method="post">
            <label for="username">Username</label>
            <input id="username" name="Username" type="text" autocomplete="username"
                   value="@Model.Username" required autofocus />

            <label for="password">Password</label>
            <input id="password" name="Password" type="password" autocomplete="current-password" required />

            <div class="remember">
                <input id="rememberMe" name="RememberMe" type="checkbox" value="true"
                       @(Model.RememberMe ? "checked" : "") />
                <label for="rememberMe" style="margin-bottom:0;font-weight:400;">Remember me</label>
            </div>

            @Html.AntiForgeryToken()
            <button type="submit" class="btn-login">Sign In</button>
        </form>
    </div>
</body>
</html>
